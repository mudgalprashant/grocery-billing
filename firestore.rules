rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUser().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isCashier() {
      return hasRole('cashier') || isAdmin();
    }

    function isActive() {
      return isSignedIn() && getUser().isActive == true;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Users can read their own profile.
    // Admins can read all profiles and update roles.
    // New users can create their own profile on first sign-in.

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (
        // User updating their own non-sensitive fields
        (request.auth.uid == uid && !('role' in request.resource.data.diff(resource.data).affectedKeys()))
        // Admin updating anything
        || isAdmin()
      );
      allow delete: if false; // Never hard-delete users
    }

    // ── Products ──────────────────────────────────────────────────────────────
    // All authenticated active users can read products.
    // Only admins can create/update/delete.

    match /products/{productId} {
      allow read: if isActive();
      allow create, update, delete: if isActive() && isAdmin();
    }

    // ── Bills ─────────────────────────────────────────────────────────────────
    // Cashiers and admins can create bills.
    // Customers can read bills linked to their UID.
    // Admins and cashiers can read all bills.
    // Only admins can update bill status.

    match /bills/{billId} {
      allow read: if isActive() && (
        isCashier()
        || resource.data.customerId == request.auth.uid
      );
      allow create: if isActive() && isCashier();
      allow update: if isActive() && isAdmin();
      allow delete: if false;
    }

    // ── Payments ──────────────────────────────────────────────────────────────
    // Any active user can register a payment.
    // Customers can read payments on their own bills.
    // Cashiers/admins can read all payments.
    // Only admins can approve/reject (update status).

    match /payments/{paymentId} {
      allow read: if isActive() && (
        isCashier()
        || resource.data.registeredByUserId == request.auth.uid
      );
      allow create: if isActive();
      allow update: if isActive() && isAdmin();
      allow delete: if false;
    }

    // ── Counters ──────────────────────────────────────────────────────────────
    // Only used server-side via transactions for bill number generation.
    // Cashiers and admins can read/write (needed for transaction).

    match /counters/{counterId} {
      allow read, write: if isActive() && isCashier();
    }
  }
}
