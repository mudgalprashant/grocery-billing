rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getRole() {
      return userExists() ? getUserData().role : null;
    }

    function getStoreId() {
      return userExists() ? getUserData().storeId : null;
    }

    function isActive() {
      return userExists() && getUserData().isActive == true;
    }

    function isAdmin() {
      return isActive() && getRole() == 'admin';
    }

    // store manager or admin
    function isStoreManager(storeId) {
      return isActive() && (
        getRole() == 'admin'
        || (getRole() == 'store' && getStoreId() == storeId)
      );
    }

    // cashier, store manager, or admin — all can create bills
    function canBill(storeId) {
      return isActive() && (
        getRole() == 'admin'
        || ((getRole() == 'store' || getRole() == 'cashier') && getStoreId() == storeId)
      );
    }

    // ── Meta ──────────────────────────────────────────────────────────────────

    match /meta/{docId} {
      allow read, write: if isSignedIn();
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (
        (request.auth.uid == uid && !('role' in request.resource.data.diff(resource.data).affectedKeys()))
        || isAdmin()
      );
      allow delete: if false;
    }

    // ── Stores ────────────────────────────────────────────────────────────────

    match /stores/{storeId} {
      allow read: if isActive();
      allow create, update: if isAdmin();
      allow delete: if false;

      // ── Products (sub-collection) ─────────────────────────────────────────

      match /products/{productId} {
        allow read: if isActive() && (isAdmin() || getStoreId() == storeId);
        allow create, update, delete: if isStoreManager(storeId);
      }

      // ── Bills (sub-collection) ────────────────────────────────────────────

      match /bills/{billId} {
        allow read: if isActive() && (
          canBill(storeId)
          || resource.data.customerId == request.auth.uid
        );
        allow create: if canBill(storeId);
        allow update: if isStoreManager(storeId);
        allow delete: if false;
      }

      // ── Payments (sub-collection) ─────────────────────────────────────────

      match /payments/{paymentId} {
        allow read: if isActive() && (
          canBill(storeId)
          || resource.data.registeredByUserId == request.auth.uid
        );
        allow create: if isActive();
        allow update: if isStoreManager(storeId);
        allow delete: if false;
      }

      // ── Counters (sub-collection) ─────────────────────────────────────────

      match /counters/{counterId} {
        allow read, write: if canBill(storeId);
      }
    }
  }
}
