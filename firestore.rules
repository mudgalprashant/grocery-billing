rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return userExists() && getUserData().role == 'admin';
    }

    function isCashier() {
      return userExists() && (getUserData().role == 'cashier' || getUserData().role == 'admin');
    }

    function isActiveUser() {
      return userExists() && getUserData().isActive == true;
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      // Anyone signed in can read their own profile
      allow read: if isSignedIn() && request.auth.uid == uid;
      // Admins can read all profiles
      allow read: if isAdmin();
      // A signed-in user can create ONLY their own profile
      allow create: if isSignedIn() && request.auth.uid == uid;
      // User can update their own non-sensitive fields; admin can update anything
      allow update: if isSignedIn() && (
        (request.auth.uid == uid && !('role' in request.resource.data.diff(resource.data).affectedKeys()))
        || isAdmin()
      );
      allow delete: if false;
    }

    // ── Invite codes ──────────────────────────────────────────────────────────
    // Used for manual registration flow — admin creates, new user reads once

    match /inviteCodes/{code} {
      // Anyone signed in can read a code to validate it
      allow read: if isSignedIn();
      // Only admins can create/delete codes
      allow create, delete: if isAdmin();
      allow update: if false;
    }

    // ── Products ──────────────────────────────────────────────────────────────

    match /products/{productId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isActiveUser() && isAdmin();
    }

    // ── Bills ─────────────────────────────────────────────────────────────────

    match /bills/{billId} {
      allow read: if isActiveUser() && (
        isCashier()
        || resource.data.customerId == request.auth.uid
      );
      allow create: if isActiveUser() && isCashier();
      allow update: if isActiveUser() && isAdmin();
      allow delete: if false;
    }

    // ── Payments ──────────────────────────────────────────────────────────────

    match /payments/{paymentId} {
      allow read: if isActiveUser() && (
        isCashier()
        || resource.data.registeredByUserId == request.auth.uid
      );
      allow create: if isActiveUser();
      allow update: if isActiveUser() && isAdmin();
      allow delete: if false;
    }

    // ── Meta ─────────────────────────────────────────────────────────────────
    // App-wide sentinel docs (e.g. admin_exists flag)
    // Any signed-in user can read; only cashiers/admins can write (via upsert)

    match /meta/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Counters ──────────────────────────────────────────────────────────────

    match /counters/{counterId} {
      allow read, write: if isActiveUser() && isCashier();
    }
  }
}
